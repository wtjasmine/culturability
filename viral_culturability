    aes(
      x = Days_from_onset,
      ymin = lower,
      ymax = upper
    ),
    fill = "#800080",
    alpha = 0.12
  ) +
  geom_line(
    data = all_pred,
    aes(
      x = Days_from_onset,
      y = pred
    ),
    color = "#800080",
    linewidth = 1.2
