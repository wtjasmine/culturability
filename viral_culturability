# ============================================================

all_pred <- bind_rows(
  pred_sars,
  pred_flu,
  pred_rsv
)

all_obs <- bind_rows(
  agg_sars,
  agg_flu,
  agg_rsv
)

all_pred$Virus <- factor(
  all_pred$Virus,
  levels = c("SARS-CoV-2", "Influenza", "RSV"),
  labels = c("A", "B", "C")
)

all_obs$Virus <- factor(
  all_obs$Virus,
  levels = c("SARS-CoV-2", "Influenza", "RSV"),
  labels = c("A", "B", "C")
)

plot_virus <- ggplot() +
  geom_point(
    data = all_obs,
    aes(
      x = Days_from_onset,
      y = prop_positive,
      size = total_n
    ),
    color = "grey40",
    alpha = 0.7
  ) +
  geom_ribbon(
