# 9. Supplementary figure: SARS-CoV-2 by specimen type
# ============================================================

agg_sample <- sars_data %>%
  group_by(Days_from_onset, Sample_type) %>%
  summarise(
    total_pos = sum(Culture_positive, na.rm = TRUE),
    total_neg = sum(Culture_negative, na.rm = TRUE),
    total_n = total_pos + total_neg,
    prop_positive = total_pos / total_n,
    .groups = "drop"
  ) %>%
  filter(total_n > 0)

pred_sample <- expand.grid(
  Days_from_onset = seq(
    min(sars_data$Days_from_onset, na.rm = TRUE),
    30,
    by = 0.1
  ),
  Sample_type = levels(sars_data$Sample_type),
  Vaccination_proportion = 0.5
)

pred_logit_sample <- predict(
  Model_multivariable,
  newdata = pred_sample,
  type = "link",
  re.form = NA,
  se.fit = TRUE
)

pred_sample <- pred_sample %>%
  mutate(
    pred = plogis(pred_logit_sample$fit),
    lower = plogis(pred_logit_sample$fit - 1.96 * pred_logit_sample$se.fit),
    upper = plogis(pred_logit_sample$fit + 1.96 * pred_logit_sample$se.fit)
  )

