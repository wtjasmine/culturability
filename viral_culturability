  ) +
  geom_hline(
    yintercept = 0.01,
    linetype = "dotted",
    color = "black",
    linewidth = 0.7
  ) +
  facet_wrap(~ Virus, nrow = 1) +
  labs(
    x = "Days from symptom onset",
    y = "Probability of positive virus culture",
    size = "Number tested"
  ) +
  scale_x_continuous(
    limits = c(0, 30),
    breaks = seq(0, 30, 5),
